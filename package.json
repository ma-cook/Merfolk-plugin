{
  "name": "merfolk-plugin",
  "displayName": "Merfolk Plugin",
  "description": "Scan a VS Code workspace and generate a merfolk.md diagram",
  "version": "0.0.7",
  "publisher": "ma-cook",
  "repository": {
    "type": "git",
    "url": "https://github.com/ma-cook/Merfolk-plugin"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:merfolk.generate"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "merfolk.generate",
        "title": "Generate Merfolk Diagram"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npx vsce package"
  },
  "dependencies": {
    "@babel/parser": "^7.23.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
